{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "USE_EMBEDDED_MONGO",
    "PORT",
    "VERCEL",
    "VERCEL_URL",
    "CORS_ORIGINS",
    "MONGOMS_DISABLE_POSTINSTALL",
    "PRISMA_SKIP_POSTINSTALL_GENERATE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".vercel/output/**",
        "packages/web/.vercel/output/**",
        "api/nest/**",
        "packages/web/api/nest/**"
      ],
      "env": ["DATABASE_URL", "USE_EMBEDDED_MONGO", "PORT", "VERCEL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
