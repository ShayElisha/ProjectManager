{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "MONGOMS_DISABLE_POSTINSTALL=1 PRISMA_SKIP_POSTINSTALL_GENERATE=1 pnpm install --frozen-lockfile",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "packages/web/dist",
  "framework": null,
  "build": {
    "env": {
      "DATABASE_URL": "mongodb://127.0.0.1:27017/nexus_build?directConnection=true",
      "VERCEL": "1",
      "MONGOMS_DISABLE_POSTINSTALL": "1",
      "PRISMA_SKIP_POSTINSTALL_GENERATE": "1"
    }
  },
  "functions": {
    "packages/web/api/health.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "packages/web/api/auth.js": {
      "maxDuration": 15,
      "memory": 256,
      "includeFiles": "packages/web/api/auth-lite/**"
    },
    "packages/web/api/index.js": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "packages/web/api/runtime/**"
    }
  },
  "rewrites": [
    { "source": "/api/auth/health", "destination": "/packages/web/api/health.js" },
    { "source": "/api/auth/login", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/auth/register", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/auth/me", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/organizations", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/projects", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/projects/:id", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/portfolio/executive", "destination": "/packages/web/api/auth.js" },
    { "source": "/api/rejections", "destination": "/packages/web/api/auth.js" },
    { "source": "/api", "destination": "/packages/web/api/index.js" },
    { "source": "/api/(.*)", "destination": "/packages/web/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
