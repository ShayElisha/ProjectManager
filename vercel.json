{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "dist",
  "framework": null,
  "build": {
    "env": {
      "DATABASE_URL": "mongodb://127.0.0.1:27017/nexus_build?directConnection=true"
    }
  },
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "packages/api/dist/**,packages/api/prisma/**,node_modules/.prisma/**,node_modules/@prisma/client/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
