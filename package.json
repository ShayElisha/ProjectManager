{
  "name": "nexus-project",
  "version": "0.1.0",
  "private": true,
  "description": "NexusProject — Advanced project management (MS Project Premium class)",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:vercel": "turbo run build --filter=@nexus/shared --filter=@nexus/api --filter=@nexus/web && node scripts/vercel-sync-dist.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
