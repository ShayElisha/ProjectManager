# MongoDB — embedded by default (data in packages/api/data/mongo)
USE_EMBEDDED_MONGO=true

# Or external MongoDB (Docker / Atlas):
# USE_EMBEDDED_MONGO=false
# DATABASE_URL=mongodb://127.0.0.1:27017/nexus_project?replicaSet=rs0
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/nexus_project

PORT=3001

# --- Vercel production (set in Vercel Dashboard → Environment Variables) ---
# DATABASE_URL=mongodb+srv://...
# CORS_ORIGINS=https://your-app.vercel.app
# USE_EMBEDDED_MONGO=false
# BOOTSTRAP_ADMIN_EMAIL=admin@nexus.local
# BOOTSTRAP_ADMIN_PASSWORD=admin1234

# WebSocket realtime (local dev only; Vercel serverless does not support socket.io)
# VITE_ENABLE_SOCKET=true
