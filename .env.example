# MongoDB — embedded by default (data in packages/api/data/mongo)
USE_EMBEDDED_MONGO=true

# Or external MongoDB (Docker / Atlas):
# USE_EMBEDDED_MONGO=false
# DATABASE_URL=mongodb://127.0.0.1:27017/nexus_project?replicaSet=rs0
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/nexus_project

PORT=3001
