{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "dist",
  "framework": null,
  "build": {
    "env": {
      "DATABASE_URL": "mongodb://127.0.0.1:27017/nexus_build?directConnection=true"
    }
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "../api/dist/**,../api/prisma/**,../../node_modules/.prisma/**,../../node_modules/@prisma/client/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
