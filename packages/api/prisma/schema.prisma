generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String     @id @default(uuid()) @map("_id")
  name               String
  defaultLocale      String     @default("he")
  defaultCurrency    String     @default("ILS")
  planId             String?
  stripeCustomerId   String?
  subscriptionStatus String?
  projects           Project[]
  resources          Resource[]
  users              User[]
  auditLogs          AuditLog[]
  programs           Program[]
  invoices           Invoice[]
  crmContacts        CrmContact[]
  crmDeals           CrmDeal[]
  orgAutomationRules OrgAutomationRule[]
}

model AuditLog {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  userName       String?
  action         String
  entityType     String
  entityId       String?
  summary        String
  metadata       Json?
  createdAt      DateTime     @default(now())
}

model Program {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  projectIds     Json         @default("[]")
  startDate      String?
  endDate        String?
}

model Invoice {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  clientName     String
  clientEmail    String?
  status         String       @default("draft")
  currency       String       @default("ILS")
  lines          Json
  total          Float
  dueDate        String?
  createdAt      DateTime     @default(now())
}

model CrmContact {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  company        String?
  phone          String?
}

model CrmDeal {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  contactId      String?
  title          String
  value          Float
  stage          String       @default("lead")
  projectId      String?
}

model OrgAutomationRule {
  id             String       @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  enabled        Boolean      @default(true)
  event          String
  actionType     String
  actionPayload  Json?
}

model ProofAsset {
  id           String   @id @default(uuid()) @map("_id")
  projectId    String
  taskId       String?
  title        String
  fileUrl      String?
  status       String   @default("pending")
  reviewerNote String?
  createdAt    DateTime @default(now())
}

model TaskPermission {
  id        String @id @default(uuid()) @map("_id")
  projectId String
  taskId    String
  userId    String
  level     String
}

model ResourcePto {
  id         String @id @default(uuid()) @map("_id")
  projectId  String
  resourceId String
  startDate  String
  endDate    String
  label      String?
}

model User {
  id             String        @id @default(uuid()) @map("_id")
  email          String        @unique
  passwordHash   String
  name           String
  role           String        @default("team_member")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  totpSecret     String?
  totpEnabled    Boolean       @default(false)
  createdAt      DateTime      @default(now())
}

model Project {
  id             String               @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  parentId       String?
  isTemplate     Boolean              @default(false)
  name           String
  description    String?
  locale         String               @default("he")
  currency       String               @default("ILS")
  startDate      String
  endDate        String?
  status         String               @default("planning")
  budgetCap      Float?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  tasks          Task[]
  dependencies   TaskDependency[]
  assignments    ResourceAssignment[]
  baselines      Baseline[]
  budgetLines    BudgetLineItem[]
  risks          ProjectRisk[]
  changeRequests ChangeRequest[]
  rejectionLogs  RejectionLog[]
  customColumns  CustomColumnDef[]
  sprints        Sprint[]
  cycles         Cycle[]
  forms          ProjectForm[]
  savedViews       SavedView[]
  automationRules  AutomationRule[]
  activityLogs     ActivityLog[]
  messages         ProjectMessage[]
  wikiPages           ProjectWikiPage[]
  guests              ProjectGuest[]
  customReports       CustomReport[]
  webhookSubscriptions WebhookSubscription[]
  goals               Goal[]
  whiteboardItems     WhiteboardItem[]
}

model CustomReport {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  widgets   Json
  createdAt DateTime @default(now())
}

model WebhookSubscription {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  url       String
  events    Json
  secret    String?
  enabled   Boolean @default(true)
}

model Goal {
  id        String      @id @default(uuid()) @map("_id")
  projectId String
  project   Project     @relation(fields: [projectId], references: [id])
  title     String
  period    String
  progress  Float       @default(0)
  keyResults KeyResult[]
}

model KeyResult {
  id           String @id @default(uuid()) @map("_id")
  goalId       String
  goal         Goal   @relation(fields: [goalId], references: [id])
  projectId    String
  title        String
  targetValue  Float
  currentValue Float  @default(0)
  unit         String?
}

model WhiteboardItem {
  id        String @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  x         Float
  y         Float
  width     Float  @default(160)
  height    Float  @default(100)
  text      String
  color     String @default("#fef08a")
}

model Task {
  id                  String   @id @default(uuid()) @map("_id")
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id])
  parentId            String?
  wbs                 String
  name                String
  status              String
  startDate           String
  endDate             String
  durationDays        Int
  percentComplete     Float    @default(0)
  isMilestone         Boolean  @default(false)
  isSummary           Boolean  @default(false)
  manuallyScheduled   Boolean  @default(false)
  constraint          String   @default("ASAP")
  constraintDate      String?
  isCritical          Boolean  @default(false)
  earlyStart          String?
  earlyFinish         String?
  lateStart           String?
  lateFinish          String?
  totalFloat          Int?
  freeFloat           Int?
  baselineStart       String?
  baselineFinish      String?
  plannedCost         Float?
  actualCost          Float?
  plannedLaborCost    Float?
  actualLaborCost     Float?
  plannedMaterialCost Float?
  actualMaterialCost  Float?
  plannedOtherCost    Float?
  actualOtherCost     Float?
  assigneeIds         Json     @default("[]")
  sortOrder           Int      @default(0)
  isPriority          Boolean  @default(false)
  pausedAt            String?
  pausedSegmentEnd    String?
  resumeDate          String?
  remainingWorkDays   Int?
  pausedAssigneeId    String?
  taskNotes           Json     @default("[]")
  tags                Json     @default("[]")
  description         String?
  descriptionHtml     String?
  issueType           String   @default("task")
  storyPoints         Int?
  sprintId            String?
  cycleId             String?
  seriesId            String?
  recurrenceRule      Json?
  customFields        Json     @default("{}")
  comments            TaskComment[]
  attachments         TaskAttachment[]
}

model CustomColumnDef {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  key       String
  label     String
  type      String
  options   Json?
}

model Sprint {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  name      String
  startDate String
  endDate   String
  goal      String?
  status    String  @default("planned")
}

model Cycle {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  name      String
  startDate String
  endDate   String
}

model ProjectForm {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  slug      String  @unique
  title     String
  enabled   Boolean @default(true)
  fields    Json
}

model SavedView {
  id        String  @id @default(uuid()) @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  userId    String?
  name      String
  viewMode  String
  filters   Json    @default("{}")
  columns   Json?
}

model AutomationRule {
  id            String  @id @default(uuid()) @map("_id")
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  name          String
  enabled       Boolean @default(true)
  triggerField  String
  triggerOp     String
  triggerValue  Json?
  actionType    String
  actionPayload Json?
}

model ActivityLog {
  id         String   @id @default(uuid()) @map("_id")
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  userId     String?
  userName   String?
  action     String
  entityType String
  entityId   String?
  summary    String
  createdAt  DateTime @default(now())
}

model ProjectMessage {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  userName  String
  body      String
  createdAt DateTime @default(now())
}

model ProjectWikiPage {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model ProjectGuest {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  email     String
  name      String?
  role      String   @default("viewer")
  token     String   @unique
  createdAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  userName  String
  body      String
  createdAt DateTime @default(now())
}

model TaskAttachment {
  id          String   @id @default(uuid()) @map("_id")
  projectId   String
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

model ActiveTimer {
  id        String    @id @default(uuid()) @map("_id")
  userId    String
  projectId String
  taskId    String?
  startedAt DateTime
  stoppedAt DateTime?
}

model TaskDependency {
  id            String  @id @default(uuid()) @map("_id")
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  predecessorId String
  successorId   String
  type          String  @default("FS")
  lagDays       Int     @default(0)
}

model Resource {
  id             String               @id @default(uuid()) @map("_id")
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  name           String
  type           String
  email          String?
  costPerHour    Float?
  costPerUnit    Float?
  maxUnits       Float                @default(1)
  calendarId     String?
  assignments    ResourceAssignment[]
}

model ResourceAssignment {
  id         String   @id @default(uuid()) @map("_id")
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  taskId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  units      Float    @default(1)
  workHours  Float
}

model Baseline {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  index     Int
  name      String
  savedAt   DateTime @default(now())
  tasks     Json
}

model TimesheetEntry {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  userId    String
  taskId    String
  date      String
  hours     Float
  status    String   @default("draft")
  notes     String?
  createdAt DateTime @default(now())
}

model BudgetLineItem {
  id            String  @id @default(uuid()) @map("_id")
  projectId     String
  project       Project @relation(fields: [projectId], references: [id])
  category      String
  name          String
  description   String?
  plannedAmount    Float   @default(0)
  committedAmount  Float?
  actualAmount     Float   @default(0)
  cashMonth        String
  taskId           String?
  source           String?
  sourceRef        String?
}

model Notification {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
}

model ProjectMember {
  id          String @id @default(uuid()) @map("_id")
  projectId   String
  resourceId  String
  role        String
  hoursPerDay Int?
}

model ProjectRisk {
  id                String   @id @default(uuid()) @map("_id")
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id])
  title             String
  description       String?
  category          String   @default("schedule")
  probability       String
  impact            String
  riskScore         Int      @default(4)
  status            String   @default("open")
  source            String   @default("manual")
  ownerResourceId   String?
  responsePlan      String?
  taskId            String?
  dedupeKey         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ChangeRequest {
  id                  String    @id @default(uuid()) @map("_id")
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id])
  title               String
  description         String?
  impactScheduleDays  Int       @default(0)
  impactCost          Float     @default(0)
  status              String    @default("draft")
  requestedBy         String?
  decidedAt           DateTime?
  decisionNote        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RejectionLog {
  id                  String   @id @default(uuid()) @map("_id")
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id])
  title               String
  description         String?
  category            String   @default("other")
  rejectedAt          String
  decisionNote        String?
  impactScheduleDays  Int?
  impactCost          Float?
  taskId              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
